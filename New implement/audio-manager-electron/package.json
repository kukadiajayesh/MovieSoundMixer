{
  "name": "audio-manager-electron",
  "version": "1.0.0",
  "description": "FFmpeg Audio Manager - Extract and merge audio from videos",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build:vite": "vite build",
    "build:electron": "electron-builder",
    "build": "npm run build:vite && npm run build:electron",
    "preview": "vite preview",
    "electron": "set NODE_ENV=development && electron .",
    "electron:dev": "set NODE_ENV=development && electron . & vite",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "bull": "^4.16.5",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "ffmpeg-static": "^5.3.0",
    "framer-motion": "^12.38.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sqlite3": "^6.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "zustand": "^5.0.13"
  },
  "build": {
    "appId": "com.ffmpeg-audio-manager.app",
    "productName": "FFmpeg Audio Manager",
    "directories": {
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": ["nsis", "portable"]
    },
    "mac": {
      "target": ["dmg", "zip"]
    },
    "linux": {
      "target": ["AppImage", "deb"]
    }
  }
}
