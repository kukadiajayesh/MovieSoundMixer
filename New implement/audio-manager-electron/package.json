{
  "name": "audio-manager-electron",
  "version": "1.0.0",
  "description": "FFmpeg Audio Manager - Extract and merge audio from videos",
  "main": "dist/main/index.js",
  "scripts": {
    "dev:vite": "vite",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:electron": "wait-on http://localhost:5173 && set NODE_ENV=development && electron .",
    "start": "concurrently \"npm run dev:vite\" \"npm run dev:main\" \"npm run dev:electron\" --kill-others",
    "build:vite": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:electron": "electron-builder",
    "build": "npm run build:vite && npm run build:main && npm run build:electron",
    "preview": "vite preview",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-react": "^6.0.1",
    "bull": "^4.16.5",
    "concurrently": "^9.2.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "ffmpeg-static": "^5.3.0",
    "framer-motion": "^12.38.0",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sqlite3": "^6.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10",
    "zustand": "^5.0.13"
  },
  "build": {
    "appId": "com.ffmpeg-audio-manager.app",
    "productName": "FFmpeg Audio Manager",
    "directories": {
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "dependencies": {
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1"
  }
}
